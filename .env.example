# Copy this file to .env and fill in your own credentials.

# arXiv source paper window
ARXIV_CATEGORY=hep-ex
ARXIV_DAYS=1
ARXIV_MAX_RESULTS=10
INCLUDE_CROSS_LIST=false

# Related paper search
RELATED_PER_PAPER=5
RELATED_SEARCH_LIMIT=20
MAX_QUERY_TERMS=5

# LLM provider. Any OpenAI-compatible chat completion endpoint can be used.
OPENAI_API_KEY=sk-xxx
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Cost estimation
USD_CNY_RATE=7.2
# Optional custom prices in USD per 1M tokens for unknown/custom models.
# LLM_INPUT_PRICE_USD_PER_1M=0.15
# LLM_OUTPUT_PRICE_USD_PER_1M=0.60

# Email notification
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_SSL=false
EMAIL_FROM=your_email@example.com
EMAIL_PASSWORD=your_email_password_or_app_password
EMAIL_TO=recipient@example.com

# Optional title translation in the email.
TRANSLATE_TITLES=false
